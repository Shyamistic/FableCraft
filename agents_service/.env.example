# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET_NAME=fablecraft-assets
CLOUDFRONT_DOMAIN=
DYNAMODB_TABLE_NAME=fablecraft-data

# Amazon Bedrock Model IDs (Nova family — request access in Bedrock console)
BEDROCK_VISION_MODEL=amazon.nova-pro-v1:0
BEDROCK_QUEST_MODEL=amazon.nova-pro-v1:0
BEDROCK_MODERATION_MODEL=amazon.nova-lite-v1:0
BEDROCK_IMAGE_MODEL=amazon.nova-canvas-v1:0

# Amazon Nova (us-east-1 only)
NOVA_VISION_MODEL=amazon.nova-pro-v1:0
NOVA_CANVAS_MODEL=amazon.nova-canvas-v1:0
NOVA_REEL_MODEL=amazon.nova-reel-v1:0
NOVA_CANVAS_ENABLED=true
NOVA_REEL_ENABLED=false
NOVA_REEL_OUTPUT_BUCKET=

# Image Generation Provider
# "auto" tries: nova_canvas → clipdrop → gemini → bedrock → pollinations
IMAGE_PROVIDER=auto
CLIPDROP_API_KEY=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Pollinations (free fallback)
POLLINATIONS_TOKEN=
POLLINATIONS_BASE_URL=https://image.pollinations.ai/prompt/
POLLINATIONS_MODEL=flux

# OpenRouter Fallback (LLM fallback provider)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_QUEST_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_MODERATION_MODEL=anthropic/claude-3.5-sonnet

# Timeouts (milliseconds)
BEDROCK_TIMEOUT_MS=15000
OPENROUTER_TIMEOUT_MS=15000
IMAGE_GENERATION_TIMEOUT_MS=30000
TTS_TIMEOUT_MS=10000

# Retry Configuration
MAX_RETRIES=3
RETRY_BASE_DELAY_MS=1000

# Amazon Polly Configuration
POLLY_VOICE_ID=Ruth
POLLY_ENGINE=neural
POLLY_SPEAKING_RATE=90%

# S3 URL Configuration
PRESIGNED_URL_EXPIRY_SECONDS=3600
CACHE_CONTROL_MAX_AGE=3600

# Parent Dashboard
PARENT_PIN=1234

# Application
APP_NAME=fablecraft
DEBUG=false
PORT=8080
